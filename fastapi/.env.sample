REDIS_HOST=redis
REDIS_PORT=6379
PYTHONUNBUFFERED=1
POSTGRES_USER=app 
POSTGRES_PASSWORD=app1234
POSTGRES_DB=appdb
POSTGRES_HOST=db
POSTGRES_PORT=5432
# ── CloZ-AI 서브모듈 ──
MODELS_ROOT=/app/models

# ── AWS S3 ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=simkim-s3-bucket
AWS_S3_REGION_NAME=us-east-1
# 인증 모드: auto | static | iam_role
# - local 개발: auto/static
# - 운영: iam_role 권장
AWS_AUTH_MODE=iam_role
AWS_PRESIGNED_URL_EXPIRE_SECONDS=3600
AWS_PROFILE=default
USE_S3=1